<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10101e"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvSetupTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Turnuva Kurulumu 🏆"
        android:textColor="#00D1FF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvSetupTitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Katılımcı Sayısı:"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/etParticipantCount"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:inputType="number"
            android:text="4"
            android:textColor="#00D26A"
            android:textAlignment="center"
            android:backgroundTint="#00D26A" />

        <Button
            android:id="@+id/btnUpdateList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Listeyi Güncelle"
            android:textSize="12sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvParticipantInputs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutCount"
        app:layout_constraintBottom_toTopOf="@id/rgGameMode" />

    <RadioGroup
        android:id="@+id/rgGameMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnStartTournament">

        <RadioButton
            android:id="@+id/rb501"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="501 Modu"
            android:textColor="#FFFFFF"
            android:checked="true"
            android:buttonTint="#00D1FF" />

        <RadioButton
            android:id="@+id/rbCricket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Kriket Modu"
            android:textColor="#FFFFFF"
            android:buttonTint="#FFD700" />
    </RadioGroup>

    <Button
        android:id="@+id/btnStartTournament"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="KURALARI ÇEK VE BAŞLAT"
        android:backgroundTint="#00D26A"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>